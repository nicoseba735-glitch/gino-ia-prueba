   <!DOCTYPE html>
<html lang="es">
<head>
        <link rel="manifest" href="manifest.json">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black">
<meta name="theme-color" content="#1e3c72">

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gino AI</title>
    <style>
        /* Estilos Generales y Fondo Azul */
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            overflow: hidden;
            position: relative;
        }

        /* Animación de Burbujas de Fondo */
        .burbujas {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 1;
            pointer-events: none;
        }

        .burbuja {
            position: absolute;
            bottom: -100px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 50%;
            animation: flotar 10s infinite linear;
        }

        @keyframes flotar {
            0% { transform: translateY(0) scale(1); opacity: 0; }
            50% { opacity: 0.5; }
            100% { transform: translateY(-110vh) scale(1.2); opacity: 0; }
        }

        /* Contenedor de la App */
        .app-container {
            width: 100%;
            max-width: 450px;
            height: 90vh;
            background: rgba(255, 255, 255, 0.15);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 20px;
            display: flex;
            flex-direction: column;
            z-index: 2;
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.3);
            overflow: hidden;
        }

        /* Cabecera / Header */
        .header {
            padding: 20px;
            background: rgba(255, 255, 255, 0.1);
            text-align: center;
            color: white;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }

        .header h1 {
            font-size: 1.5rem;
            letter-spacing: 1px;
        }

        .header p {
            font-size: 0.8rem;
            opacity: 0.8;
        }

        /* Zona de Mensajes */
        .chat-box {
            flex: 1;
            padding: 20px;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        /* Estilo de los Globos de Mensaje */
        .mensaje {
            max-width: 80%;
            padding: 12px 16px;
            border-radius: 15px;
            color: white;
            font-size: 0.95rem;
            line-height: 1.4;
            word-wrap: break-word;
        }

        .gino {
            background: rgba(255, 255, 255, 0.2);
            align-self: flex-start;
            border-top-left-radius: 2px;
        }

        .usuario {
            background: linear-gradient(to right, #0072ff, #00c6ff);
            align-self: flex-end;
            border-top-right-radius: 2px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }

        /* Barra de Entrada de Texto y Botones */
        .input-area {
            padding: 15px;
            background: rgba(0, 0, 0, 0.2);
            display: flex;
            gap: 10px;
            align-items: center;
        }

        .input-area input {
            flex: 1;
            padding: 12px;
            border: none;
            border-radius: 25px;
            background: rgba(255, 255, 255, 0.9);
            outline: none;
            font-size: 1rem;
        }

        .btn {
            background: #00c6ff;
            border: none;
            width: 45px;
            height: 45px;
            border-radius: 50%;
            color: white;
            cursor: pointer;
            font-size: 1.2rem;
            display: flex;
            justify-content: center;
            align-items: center;
            transition: transform 0.2s;
            user-select: none;
            -webkit-user-select: none;
        }

        .btn:active {
            transform: scale(0.9);
        }

        .btn-voz {
            background: linear-gradient(to right, #ff4b2b, #ff416c);
        }
    </style>
</head>
<body>

    <div class="burbujas" id="contenedor-burbujas"></div>

    <div class="app-container">
        <div class="header">
            <h1>Gino</h1>
            <p id="estado">● En línea</p>
        </div>

        <div class="chat-box" id="chatBox">
            <div class="mensaje gino">
                ¡Hola! Soy Gino, soy una ia (engau) de Nico.B y estoy acá para ayudarte. ¿De qué te gustaría charlar hoy? 😊
            </div>
        </div>

        <div class="input-area">
            <input type="text" id="userInput" placeholder="Escribe un mensaje..." onkeypress="detectarEnter(event)">
            <button class="btn" onclick="enviarMensaje()">➤</button>
            <button class="btn btn-voz" id="btnVoz" onclick="controlarAudio()">🎤</button>
        </div>
    </div>

    <script>
        // ==========================================
        // CONFIGURACIÓN: TU API KEY
        // ==========================================
        const API_KEY = "AQ.Ab8RN6JamultzrwNpj1nbfogkQ-vqkgyxhFxhMaaTwoIPlPbWA"; 

        // Burbujas
        const contenedor = document.getElementById('contenedor-burbujas');
        for (let i = 0; i < 15; i++) {
            let burbuja = document.createElement('div');
            burbuja.classList.add('burbuja');
            let tamano = Math.random() * 60 + 20;
            burbuja.style.width = `${tamano}px`;
            burbuja.style.height = `${tamano}px`;
            burbuja.style.left = `${Math.random() * 100}%`;
            burbuja.style.animationDelay = `${Math.random() * 8}s`;
            burbuja.style.animationDuration = `${Math.random() * 5 + 7}s`;
            contenedor.appendChild(burbuja);
        }

        const chatBox = document.getElementById('chatBox');
        const userInput = document.getElementById('userInput');
        const estado = document.getElementById('estado');

        // Enviar Texto Normal
        async function enviarMensaje() {
            const texto = userInput.value.trim();
            if (texto === "") return;

            agregarMensaje(texto, 'usuario');
            userInput.value = "";
            procesarConGemini(texto);
        }

        // Conectar con el cerebro de Google Gemini
        async function procesarConGemini(textoPrompt) {
            if (API_KEY === "TU_API_KEY_ACA") {
                setTimeout(() => {
                    agregarMensaje("¡Hola! Acordate de poner tu API Key en la línea 121 del código.", 'gino');
                }, 1000);
                return;
            }

            try {
                estado.innerText = "● Gino está pensando...";
                estado.style.color = "#ffeb3b";

                const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=${API_KEY}`;
                const data = {
                    contents: [{ parts: [{ text: textoPrompt }] }],
                    systemInstruction: {
                        parts: [{ text: "Tu nombre es Gino. Sos una inteligencia artificial amigable creada por Nicolas Brizuela para ayudar al usuario. Hablás en español latino corto, alegre y fluido." }]
                    }
                };

                const respuesta = await fetch(url, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                const resultadoJson = await respuesta.json();
                const respuestaIA = resultadoJson.candidates[0].content.parts[0].text;
                agregarMensaje(respuestaIA, 'gino');

            } catch (error) {
                console.error(error);
                agregarMensaje("Che, se me cortó la onda con el servidor. Revisá la API Key.", 'gino');
            } finally {
                estado.innerText = "● En línea";
                estado.style.color = "white";
            }
        }

        function detectarEnter(event) {
            if (event.key === "Enter") enviarMensaje();
        }

        function agregarMensaje(texto, remitente) {
            const nuevoMensaje = document.createElement('div');
            nuevoMensaje.classList.add('mensaje', remitente);
            nuevoMensaje.innerText = texto;
            chatBox.appendChild(nuevoMensaje);
            chatBox.scrollTop = chatBox.scrollHeight;
        }

                // ==========================================
        // 🎙️ SISTEMA DE RECONOCIMIENTO DE VOZ RE-ACTIVADO
        // ==========================================
        let reconocimiento;
        let grabando = false;

        const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
        
        if (SpeechRecognition) {
            reconocimiento = new SpeechRecognition();
            reconocimiento.lang = 'es-AR';
            reconocimiento.continuous = false;
            reconocimiento.interimResults = false;

            reconocimiento.onstart = () => {
                grabando = true;
                document.getElementById('btnVoz').innerText = "🛑";
                document.getElementById('btnVoz').style.background = "#333";
                estado.innerText = "● Gino escuchando...";
                estado.style.color = "#4caf50";
            };

            reconocimiento.onresult = (event) => {
                const textoEscuchado = event.results[0][0].transcript;
                userInput.value = textoEscuchado;
                enviarMensaje(); 
            };

            reconocimiento.onend = () => {
                grabando = false;
                document.getElementById('btnVoz').innerText = "🎤";
                document.getElementById('btnVoz').style.background = "linear-gradient(to right, #ff4b2b, #ff416c)";
                estado.innerText = "● En línea";
                estado.style.color = "white";
            };
        }

        window.controlarAudio = function() {
            if (!reconocimiento) {
                alert("El reconocimiento de voz no está disponible o está bloqueado.");
                return;
            }
            if (grabando) {
                reconocimiento.stop();
            } else {
                reconocimiento.start();
            }
        }

    </script>
</body>
</html>
